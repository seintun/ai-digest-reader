# DailyDigest — Environment Variables
# Copy this file to .env and fill in values

# ── AI Summarization ──────────────────────────────────────────────────────────
# OpenRouter API key (https://openrouter.ai — free tier available)
# If not set, falls back to Claude CLI (requires `claude` installed)
OPENROUTER_API_KEY=

# ── Engine Selection ─────────────────────────────────────────────────────────
# standalone: use AI Digest's local pipeline and project-local OpenRouter key if configured
# openclaw: explicitly delegate selected stages to OpenClaw/research-engine
AI_DIGEST_ENGINE=standalone
AI_DIGEST_OPENCLAW_STAGES=summary
AI_DIGEST_OPENCLAW_PROFILE=digest
AI_DIGEST_OPENCLAW_ON_FAILURE=fail-no-deploy
# Optional override for development/tests. Defaults to the local research-engine checkout.
AI_DIGEST_OPENCLAW_COMMAND=

# ── Vercel Deployment (GitHub Actions only) ───────────────────────────────────
# Required only for automated deployment via GitHub Actions.
# Leave blank if deploying via Vercel's GitHub integration (recommended).
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
