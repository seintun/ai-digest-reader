        }).join('')}
      </div>
    `;
  }

  function updateSourceFilter() {
    const counts = getSourceCounts(state.stories);
    document.querySelectorAll('.source-btn').forEach(btn => {
      const src = btn.getAttribute('data-source');
      const countEl = btn.querySelector('.count');
      if (!countEl) return;
      if (src === 'all') countEl.textContent = counts.total.toString();
      else if (src === 'reddit') countEl.textContent = counts.reddit.toString();
      else if (src === 'hn') countEl.textContent = counts.hn.toString();
      else if (src === 'rss') countEl.textContent = counts.rss.toString();
    });
  }

  function showLoading() {
    state.isLoading = true;
    elements.loadingContainer?.classList.remove('hidden');
    elements.errorContainer?.classList.add('hidden');
    elements.storiesContainer?.classList.add('opacity-50', 'pointer-events-none');
  }

  function hideLoading() {
    state.isLoading = false;
    elements.loadingContainer?.classList.add('hidden');
    elements.storiesContainer?.classList.remove('opacity-50', 'pointer-events-none');
    
    if (elements.summaryContainer && state.summary) {
      elements.summaryContainer.innerHTML = renderDigestSummary(
        state.summary,
        state.stories,
        state.summaryCostUsd,
        state.summaryCostAvailable,
      );
      initSummaryTabs();
    }
  }

  function getStoryUrl(stories: Story[], id: string): string {
    const story = stories.find(s => s.i === id);
    return safeExternalUrl(story?.u);
  }

  function renderDigestSummary(
    summary: DigestSummaryType,
    stories: Story[],
    summaryCostUsd: number | null,
    summaryCostAvailable: boolean,
  ): string {
    const themesHtml = summary.structured.themes.map((t: string) =>
      '<span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-primary-100 dark:bg-primary-900/50 text-primary-700 dark:text-primary-300">' + escapeHtml(t) + '</span>'
    ).join('');

    const breakingHtml = summary.structured.breaking
      ? '<div class="p-2.5 bg-red-50 dark:bg-red-900/20 rounded-lg border border-red-200 dark:border-red-800/50"><h4 class="text-xs font-semibold text-red-600 dark:text-red-400 uppercase tracking-wider mb-1 flex items-center gap-1"><svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>Breaking</h4><p class="text-sm text-red-800 dark:text-red-300">' + escapeHtml(summary.structured.breaking) + '</p></div>'
      : '';

    const mustReadHtml = summary.structured.mustRead.map((item: MustReadItem, idx: number) =>
      '<a href="' + getStoryUrl(stories, item.id) + '" target="_blank" rel="noopener noreferrer" class="flex items-start gap-3 group cursor-pointer p-2.5 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700/30 transition-colors duration-150">' +
        '<span class="flex-shrink-0 w-6 h-6 rounded-full bg-primary-500 dark:bg-primary-600 text-white text-xs font-bold flex items-center justify-center">' + (idx + 1) + '</span>' +
        '<div class="flex-1 min-w-0">' +
          '<p class="text-sm font-medium text-slate-900 dark:text-slate-100 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors duration-150">' + escapeHtml(item.title) + '</p>' +
          '<p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">' + escapeHtml(item.reason) + '</p>' +
        '</div>' +
        '<svg class="flex-shrink-0 w-4 h-4 text-slate-400 group-hover:text-primary-500 transition-colors duration-150 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>' +
      '</a>'
    ).join('');
    
    const summaryCostLine = summaryCostAvailable && summaryCostUsd !== null
      ? '<br>· AI summary cost: $' + summaryCostUsd.toFixed(5)
      : '';

    return '<div class="digest-summary bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl p-4 mb-4 shadow-sm">' +
      '<div class="flex items-center justify-between mb-3">' +
        '<div class="flex items-center gap-2">' +
          '<div class="w-8 h-8 rounded-lg bg-gradient-to-br from-primary-500 to-primary-600 flex items-center justify-center">' +
            '<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>' +
          '</div>' +
          '<span class="font-bold text-base text-slate-900 dark:text-white">AI Summary</span>' +
        '</div>' +
        '<span class="text-xs text-slate-400 dark:text-slate-500 text-right leading-tight">Insights are AI-generated<br>· may be inaccurate' + summaryCostLine + '</span>' +
      '</div>' +
      '<div class="swipe-track-outer" id="swipe-track-outer">' +
        '<div class="swipe-track" id="swipe-track">' +
          '<div class="swipe-card">' +
            '<div class="card-snippet">' +
              '<p class="text-slate-700 dark:text-slate-200 text-sm leading-relaxed font-medium">' + escapeHtml(summary.simple) + '</p>' +
            '</div>' +
            '<div class="card-snippet-fade"></div>' +
            '<button type="button" class="card-view-more mt-2 text-sm font-medium text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300">View more ↓</button>' +
          '</div>' +
          '<div class="swipe-card">' +
            '<div class="card-snippet">' +
              '<div class="space-y-3">' +
                '<div><h4 class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">Key Themes</h4><div class="flex flex-wrap gap-2">' + themesHtml + '</div></div>' +
                breakingHtml +
                '<div><h4 class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">Must Read</h4><div class="space-y-1 bg-slate-50 dark:bg-slate-800/50 rounded-lg p-1">' + mustReadHtml + '</div></div>' +
              '</div>' +
            '</div>' +
            '<div class="card-snippet-fade"></div>' +
            '<button type="button" class="card-view-more mt-2 text-sm font-medium text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300">View more ↓</button>' +
          '</div>' +
          '<div class="swipe-card">' +
            '<div class="card-snippet">' +
              '<div id="full-brief-content" class="digest-prose text-sm text-slate-700 dark:text-slate-200 leading-relaxed"></div>' +
            '</div>' +
            '<div class="card-snippet-fade"></div>' +
            '<button type="button" class="card-view-more mt-2 text-sm font-medium text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300">View more ↓</button>' +
          '</div>' +
        '</div>' +
      '</div>' +
      '<div class="mt-3 flex items-center justify-between gap-3">' +
        '<button type="button" id="summary-prev-btn" class="h-8 w-8 rounded-full border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 disabled:opacity-40 disabled:cursor-not-allowed hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors" aria-label="Previous summary card">' +
          '<svg class="mx-auto h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>' +
        '</button>' +
        '<div class="flex items-center gap-2" aria-label="Summary cards">' +
          '<button type="button" class="swipe-dot active" data-index="0" aria-label="Show Simple summary"></button>' +
          '<button type="button" class="swipe-dot" data-index="1" aria-label="Show Structured summary"></button>' +
          '<button type="button" class="swipe-dot" data-index="2" aria-label="Show Full Brief summary"></button>' +
        '</div>' +
        '<button type="button" id="summary-next-btn" class="h-8 w-8 rounded-full border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 disabled:opacity-40 disabled:cursor-not-allowed hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors" aria-label="Next summary card">' +
          '<svg class="mx-auto h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>' +
        '</button>' +
      '</div>' +
    '</div>';
  }

  function initSummaryTabs() {
    const outer = document.getElementById('swipe-track-outer');
    const track = document.getElementById('swipe-track') as HTMLElement | null;
    const prevBtn = document.getElementById('summary-prev-btn') as HTMLButtonElement | null;
    const nextBtn = document.getElementById('summary-next-btn') as HTMLButtonElement | null;
    const dots = document.querySelectorAll('.swipe-dot');
    const fullBriefContent = document.getElementById('full-brief-content');

    if (fullBriefContent) {
      const summaryData = state.summary;
      if (summaryData) {
        const fb = summaryData.fullBrief;
        let html = '<p class="mb-3 text-sm leading-relaxed">' + escapeHtml(fb.intro) + '</p>';
        fb.sections.forEach((sec: FullBriefSection) => {
          html += '<h3 class="text-base font-semibold text-slate-800 dark:text-slate-100 mt-4 mb-2">' + escapeHtml(sec.heading) + '</h3>';
          html += '<p class="mb-2 text-sm leading-relaxed">' + escapeHtml(sec.body) + '</p>';
        });
        html += '<p class="mt-3 text-xs text-slate-500 dark:text-slate-400 italic">' + escapeHtml(fb.closing) + '</p>';
        fullBriefContent.innerHTML = html;
      }
    }

    if (!outer || !track || !prevBtn || !nextBtn || dots.length === 0) return;

    let current = 0;
    const total = 3;
    const cards = Array.from(track.querySelectorAll('.swipe-card')) as HTMLElement[];

    function isInteractiveTarget(target: EventTarget | null): boolean {
      const element = target as HTMLElement | null;
      return Boolean(element?.closest('button, a'));
    }

    function goTo(index: number) {
      current = Math.max(0, Math.min(total - 1, index));
      track!.style.transform = 'translateX(-' + (current * 100) + '%)';
      dots.forEach((dot, idx) => {
        dot.classList.toggle('active', idx === current);
      });
      prevBtn!.disabled = current === 0;
      nextBtn!.disabled = current === total - 1;
      const activeCard = cards[current];
      if (activeCard && outer) {
        // Use offsetHeight to get the current visible height including the snippet's max-height constraint
        outer.style.height = activeCard.offsetHeight + 'px';
      }
      
      // Return to the top of the page to show header and title
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    prevBtn.addEventListener('click', () => goTo(current - 1));
    nextBtn.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => goTo(index));
    });



    let dragging = false;
    let pointerStartX = 0;

    outer.addEventListener('pointerdown', (event) => {
      if (event.button !== 0 || isInteractiveTarget(event.target)) return;
      dragging = true;
      pointerStartX = event.clientX;
      (event.currentTarget as HTMLElement).setPointerCapture(event.pointerId);
    });

    outer.addEventListener('pointermove', () => {
      if (!dragging) return;
    });

    outer.addEventListener('pointerup', (event) => {
      if (!dragging) return;
      dragging = false;
      const dx = event.clientX - pointerStartX;
      if (Math.abs(dx) > 40) {
        goTo(dx < 0 ? current + 1 : current - 1);
      }
    });

    outer.addEventListener('pointercancel', () => {
      dragging = false;
    });

    const viewMoreButtons = Array.from(document.querySelectorAll('.card-view-more')) as HTMLButtonElement[];
    const snippets = Array.from(document.querySelectorAll('.card-snippet')) as HTMLElement[];
    const fades = Array.from(document.querySelectorAll('.card-snippet-fade')) as HTMLElement[];
    function setCardExpanded(cardIndex: number, expanded: boolean) {
      const snippet = snippets[cardIndex];
      const fade = fades[cardIndex];
      const btn = viewMoreButtons[cardIndex];
      if (!snippet || !fade || !btn) return;

      snippet.classList.toggle('expanded', expanded);
      snippet.style.maxHeight = expanded ? snippet.scrollHeight + 'px' : '9rem';
      fade.style.opacity = (expanded || snippet.scrollHeight <= 144) ? '0' : '1';
      btn.setAttribute('aria-expanded', expanded ? 'true' : 'false');
      btn.textContent = expanded ? 'Show less ↑' : 'View more ↓';

      if (cardIndex === current) {
        const activeCard = cards[current];
        if (activeCard && outer) {
          // Calculate target height: card height - current snippet height + target snippet height
          const currentSnippetHeight = snippet.offsetHeight;
          const targetSnippetHeight = expanded ? snippet.scrollHeight : Math.min(snippet.scrollHeight, 144);
          const currentCardHeight = activeCard.offsetHeight;
          const targetCardHeight = currentCardHeight - currentSnippetHeight + targetSnippetHeight;
          
          outer.style.height = targetCardHeight + 'px';
        }
      }
    }

    viewMoreButtons.forEach((btn, index) => {
      setCardExpanded(index, false);
      btn.addEventListener('click', () => {
        const isExpanded = snippets[index]?.classList.contains('expanded') ?? false;
        setCardExpanded(index, !isExpanded);
      });
    });

    goTo(0);
  }

  function showError(message: string) {
    state.error = message;
    hideLoading();
    elements.errorContainer?.classList.remove('hidden');
    if (elements.errorMessage) {
      elements.errorMessage.textContent = message;
    }
  }

  function renderBookmarks() {
    const bookmarked = state.stories.filter(s => state.bookmarks.has(s.i));
    if (!elements.storiesCards) return;
    elements.storiesCards.innerHTML = bookmarked.length > 0
      ? `<div class="mb-2 text-sm font-medium text-slate-500 dark:text-slate-400">${bookmarked.length} saved stor${bookmarked.length !== 1 ? 'ies' : 'y'}</div>
         <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
           ${bookmarked.map((story, i) => renderStoryCard(story, i)).join('')}
         </div>`
      : '<div class="text-center py-12 text-slate-400 dark:text-slate-500">No bookmarks yet. Tap the bookmark icon on any story.</div>';
    [elements.storiesList, elements.storiesGlance].forEach(el => el?.classList.add('hidden'));
    elements.storiesCards.classList.remove('hidden');
    elements.emptyContainer?.classList.add('hidden');
  }

  async function fetchDigest() {
    showLoading();
    try {
      const response = await fetch('/data/digest.json');
      if (!response.ok) {
        throw new Error(`Failed to fetch digest: ${response.status}`);
      }
      const data: Digest = await response.json();

      state.stories = [...data.r, ...(data.rs ?? []), ...data.h].sort((a, b) => {
        const ar = typeof a.rank === 'number' ? a.rank : Number.NEGATIVE_INFINITY;
        const br = typeof b.rank === 'number' ? b.rank : Number.NEGATIVE_INFINITY;
        if (ar !== br) return br - ar;
        return (b.s ?? 0) - (a.s ?? 0);
      });
      state.filteredStories = filterStories(state.stories, state.source, state.category, state.searchQuery);
      state.summary = data.summary || null;
      const summaryCostRaw = (data.metrics as any)?.cost?.summary_llm?.cost_usd;
      const summaryCostSourceRaw = (data.metrics as any)?.cost?.summary_llm?.cost_source;
      state.summaryCostUsd = typeof summaryCostRaw === 'number' ? summaryCostRaw : null;
      state.summaryCostAvailable = summaryCostSourceRaw === 'openrouter_usage';

      updateSourceFilter();
      renderStories();
      hideLoading();
      window.updateBookmarkBadge?.(state.bookmarks.size);
    } catch (error) {
      console.error('Error fetching digest:', error);
      showError(error instanceof Error ? error.message : 'Failed to load stories');
    }
  }

  function handleViewChange(event: Event) {
    const customEvent = event as CustomEvent<{ mode: ViewMode }>;
    state.viewMode = customEvent.detail.mode;

    if (elements.storiesContainer) {
      elements.storiesContainer.classList.add('opacity-0');
      setTimeout(() => {
        renderStories();
        elements.storiesContainer?.classList.remove('opacity-0');
      }, 150);
    } else {
      renderStories();
    }
  }

  function handleSourceChange(event: Event) {
    const customEvent = event as CustomEvent<{ source: Source }>;
    state.source = customEvent.detail.source;
    state.filteredStories = filterStories(state.stories, state.source, state.category, state.searchQuery);
    renderStories();
  }

  async function resolveHnDiscussionUrl(articleUrl: string): Promise<string> {
    const endpoint = `https://hn.algolia.com/api/v1/search?query=${encodeURIComponent(articleUrl)}&restrictSearchableAttributes=url&tags=story`;
    const response = await fetch(endpoint);
    if (!response.ok) {
      throw new Error(`HN lookup failed: ${response.status}`);
    }
    const payload = await response.json();
    const firstHit = payload?.hits?.[0];
    const storyId = firstHit?.story_id ?? firstHit?.objectID;
    if (!storyId) {
      return `https://hn.algolia.com/?query=${encodeURIComponent(articleUrl)}`;
    }
    return `https://news.ycombinator.com/item?id=${storyId}`;
  }

  async function handleCommentLinkClick(link: HTMLAnchorElement) {
    const source = link.dataset.source;
    const directUrl = link.dataset.discussionUrl;
    const storyUrl = link.dataset.storyUrl || '';

    if (directUrl || source !== 'hn') {
      return;
    }

    const popup = window.open('about:blank', '_blank', 'noopener,noreferrer');
    link.classList.add('opacity-60', 'pointer-events-none');

    try {
      const resolvedUrl = safeExternalUrl(await resolveHnDiscussionUrl(storyUrl));
      const fallbackUrl = safeExternalUrl(`https://hn.algolia.com/?query=${encodeURIComponent(storyUrl)}`);
      const targetUrl = resolvedUrl === '#' ? fallbackUrl : resolvedUrl;
      if (popup) {
        popup.location.href = targetUrl;
      } else {
        window.location.href = targetUrl;
      }
    } catch {
      const fallbackUrl = safeExternalUrl(`https://hn.algolia.com/?query=${encodeURIComponent(storyUrl)}`);
      if (popup) {
        popup.location.href = fallbackUrl;
      } else {
        window.location.href = fallbackUrl;
      }
    } finally {
      link.classList.remove('opacity-60', 'pointer-events-none');
    }
  }

  document.addEventListener('viewchange', handleViewChange);
  document.addEventListener('sourcechange', handleSourceChange);

  document.addEventListener('searchchange', ((e: CustomEvent<{ query: string }>) => {
    const { query } = e.detail;
    state.searchQuery = query;
    state.filteredStories = filterStories(state.stories, state.source, state.category, state.searchQuery);
    renderStories();
    window.updateSearchInfo?.(state.filteredStories.length, query);
  }) as EventListener);

  document.addEventListener('categorychange', ((e: CustomEvent<{ category: string }>) => {
    const { category } = e.detail;
    state.category = category as Category;
    state.filteredStories = filterStories(state.stories, state.source, state.category, state.searchQuery);
    renderStories();
  }) as EventListener);

  document.addEventListener('navchange', ((e: CustomEvent<{ nav: string }>) => {
    const { nav } = e.detail;
    window.setNavActive?.(nav);
    const searchWrapper = document.getElementById('search-wrapper');
    if (nav === 'search') {
      searchWrapper?.classList.remove('hidden');
      document.getElementById('search-input')?.focus();
    }
    if (nav === 'bookmarks') {
      renderBookmarks();
    }
    if (nav === 'home') {
      renderStories();
    }
  }) as EventListener);
  document.addEventListener('click', (event) => {
    const target = event.target as HTMLElement | null;
    const link = target?.closest('a[data-comment-link="true"]') as HTMLAnchorElement | null;
    if (!link) return;

    const directUrl = link.dataset.discussionUrl;
    if (!directUrl && link.dataset.source === 'hn') {
      event.preventDefault();
      void handleCommentLinkClick(link);
    }
  });

  document.addEventListener('click', (e: Event) => {
    const btn = (e.target as Element).closest('.bookmark-btn') as HTMLElement | null;
    if (!btn) return;
    const id = btn.getAttribute('data-story-id');
    if (!id) return;
    if (state.bookmarks.has(id)) {
      state.bookmarks.delete(id);
      btn.setAttribute('aria-pressed', 'false');
      btn.querySelector('svg')?.setAttribute('fill', 'none');
    } else {
      state.bookmarks.add(id);
      btn.setAttribute('aria-pressed', 'true');
      btn.querySelector('svg')?.setAttribute('fill', 'currentColor');
    }
    saveBookmarks(state.bookmarks);
    window.updateBookmarkBadge?.(state.bookmarks.size);
  });

  elements.retryButton?.addEventListener('click', fetchDigest);

  let touchStartY = 0;
  let touchEndY = 0;

  document.addEventListener('touchstart', (e) => {
    if (window.scrollY === 0) {
      touchStartY = e.changedTouches[0].screenY;
    }
  }, { passive: true });

  document.addEventListener('touchend', (e) => {
    touchEndY = e.changedTouches[0].screenY;
    const pullDistance = touchEndY - touchStartY;

    if (pullDistance > 80 && window.scrollY === 0) {
      if (elements.pullRefreshHint) {
        elements.pullRefreshHint.style.opacity = '0';
      }
      fetchDigest();
    }
  }, { passive: true });

  if (window.scrollY === 0) {
    if (elements.pullRefreshHint) {
      elements.pullRefreshHint.style.opacity = '1';
      setTimeout(() => {
        if (elements.pullRefreshHint) {
          elements.pullRefreshHint.style.opacity = '0';
        }
      }, 3000);
    }
  }

  fetchDigest();
</script>

