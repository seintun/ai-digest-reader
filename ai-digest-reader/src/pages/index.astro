---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Controls from '../components/Controls.astro';
import SearchBar from '../components/SearchBar.astro';
import CategoryFilter from '../components/CategoryFilter.astro';
import BottomNav from '../components/BottomNav.astro';
---

<Base title="AI Digest - Your Daily AI News">
  <Header />

  <main class="max-w-4xl mx-auto px-2 sm:px-3 py-2 sm:py-3">
    <div id="summary-container"></div>
    
    <div id="controls-container" class="mb-3">
      <Controls />
    </div>

    <SearchBar />
    <CategoryFilter />

    <div id="pull-refresh-hint" class="flex items-center justify-center gap-2 mb-3 text-xs text-slate-400 dark:text-slate-500 opacity-0 transition-opacity duration-300">
      <svg class="w-3 h-3 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
      <span>Pull down to refresh</span>
    </div>

    <div id="loading-container" class="hidden">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3" id="loading-cards">
        {[...Array(6)].map(() => (
          <div class="bg-slate-900 border border-slate-800 rounded-xl p-4 animate-pulse">
            <div class="flex items-center gap-2 mb-2">
              <div class="h-5 w-12 bg-slate-200 dark:bg-slate-700 rounded"></div>
            </div>
            <div class="space-y-1.5 mb-3">
              <div class="h-4 bg-slate-700/70 rounded w-full"></div>
              <div class="h-4 bg-slate-700/70 rounded w-2/3"></div>
            </div>
            <div class="space-y-1.5 mb-4">
              <div class="h-3 bg-slate-800 rounded w-full"></div>
              <div class="h-3 bg-slate-800 rounded w-4/5"></div>
            </div>
            <div class="flex items-center justify-between">
              <div class="h-3 bg-slate-800 rounded w-20"></div>
              <div class="flex items-center gap-2">
                <div class="h-3 w-6 bg-slate-800 rounded"></div>
                <div class="h-3 w-6 bg-slate-800 rounded"></div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div id="error-container" class="hidden">
      <div class="backdrop-blur-md bg-white/70 dark:bg-slate-800/60 border border-red-200 dark:border-red-800/50 rounded-2xl p-8 text-center">
        <svg class="w-12 h-12 mx-auto mb-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <h3 class="text-lg font-medium text-slate-900 dark:text-white mb-2">Failed to load stories</h3>
        <p id="error-message" class="text-slate-500 dark:text-slate-400 mb-4">Something went wrong</p>
        <button
          id="retry-button"
          class="inline-flex items-center gap-2 px-4 py-2 bg-primary-500 hover:bg-primary-600 text-white rounded-lg transition-colors duration-200"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
          Try Again
        </button>
      </div>
    </div>

    <div id="stories-container" class="transition-opacity duration-300">
      <div id="stories-cards" class="view-content"></div>
      <div id="stories-list" class="view-content hidden"></div>
      <div id="stories-glance" class="view-content hidden"></div>
    </div>

    <div id="empty-container" class="hidden">
      <div class="backdrop-blur-md bg-white/70 dark:bg-slate-800/60 border border-white/20 dark:border-slate-700/50 rounded-2xl p-8 text-center">
        <svg class="w-12 h-12 mx-auto mb-4 text-slate-300 dark:text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
        </svg>
        <h3 class="text-lg font-medium text-slate-900 dark:text-white mb-2">No stories found</h3>
        <p class="text-slate-500 dark:text-slate-400">Try adjusting your filters or check back later</p>
      </div>
    </div>
  </main>
  <BottomNav />
</Base>

<script>
  import type { Story, Digest, DigestSummary as DigestSummaryType, ViewMode, Source, Category, MustReadItem, FullBriefSection } from '../types';
  import { getStorySource } from '../types';
  import { rankStories } from '../lib/ranking';
  import { escapeHtml, safeExternalUrl, getDiscussionUrl, getSourceCounts, getStoryAttribution } from '../lib/utils';
  import { loadBookmarks, saveBookmarks } from '../lib/storage';
  import type {} from '../lib/window-hooks';

  interface AppState {
    stories: Story[];
    filteredStories: Story[];
    summary: DigestSummaryType | null;
    summaryCostUsd: number | null;
    summaryCostAvailable: boolean;
    viewMode: ViewMode;
    source: Source;
    isLoading: boolean;
    error: string | null;
    searchQuery: string;
    category: Category;
    bookmarks: Set<string>;
  }

  const state: AppState = {
    stories: [],
    filteredStories: [],
    summary: null,
    summaryCostUsd: null,
    summaryCostAvailable: false,
    viewMode: 'cards',
    source: 'all',
    isLoading: true,
    error: null,
    searchQuery: '',
    category: 'all',
    bookmarks: loadBookmarks(),
  };

  const elements = {
    loadingContainer: document.getElementById('loading-container'),
    errorContainer: document.getElementById('error-container'),
    errorMessage: document.getElementById('error-message'),
    retryButton: document.getElementById('retry-button'),
    storiesContainer: document.getElementById('stories-container'),
    emptyContainer: document.getElementById('empty-container'),
    storiesCards: document.getElementById('stories-cards'),
    storiesList: document.getElementById('stories-list'),
    storiesGlance: document.getElementById('stories-glance'),
    pullRefreshHint: document.getElementById('pull-refresh-hint'),
    summaryContainer: document.getElementById('summary-container'),
  };

  function filterStories(stories: Story[], source: Source, category: Category, searchQuery: string): Story[] {
    let filtered = stories;

    // Source filter
    if (source !== 'all') {
      filtered = filtered.filter(story => {
        if (source === 'reddit') return story.i.startsWith('rd-');
        if (source === 'hn') return story.i.startsWith('hn-');
        if (source === 'rss') return story.i.startsWith('rs-');
        return true;
      });
    }

    // Category filter
    if (category !== 'all') {
      filtered = filtered.filter(story => story.cat === category);
    }

    // Search filter
    if (searchQuery) {
      filtered = filtered.filter(story =>
        story.t.toLowerCase().includes(searchQuery) ||
        (story.b ?? '').toLowerCase().includes(searchQuery)
      );
    }

    // Rank for "all" source with no filters active
    if (source === 'all' && category === 'all' && !searchQuery) {
      return rankStories(filtered);
    }
    return filtered;
  }

  function renderStories() {
    if (!elements.storiesCards || !elements.storiesList || !elements.storiesGlance) return;

    const { filteredStories, viewMode } = state;

    [elements.storiesCards, elements.storiesList, elements.storiesGlance].forEach(el => {
      el?.classList.add('hidden');
    });

    if (viewMode === 'cards' && elements.storiesCards) {
      elements.storiesCards.innerHTML = filteredStories.length > 0
        ? `<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">${
            filteredStories.map((story, index) => renderStoryCard(story, index)).join('')
          }</div>`
        : '';
      if (elements.storiesList) {
        elements.storiesList.innerHTML = '';
      }
      if (elements.storiesGlance) {
        elements.storiesGlance.innerHTML = '';
      }
      elements.storiesCards?.classList.remove('hidden');
    } else if (viewMode === 'list' && elements.storiesList) {
      elements.storiesList.innerHTML = filteredStories.length > 0
        ? renderStoryList(filteredStories)
        : '';
      if (elements.storiesCards) {
        elements.storiesCards.innerHTML = '';
      }
      if (elements.storiesGlance) {
        elements.storiesGlance.innerHTML = '';
      }
      elements.storiesList?.classList.remove('hidden');
    } else if (elements.storiesGlance) {
      elements.storiesGlance.innerHTML = filteredStories.length > 0
        ? renderStoryGlance(filteredStories)
        : '';
      if (elements.storiesCards) {
        elements.storiesCards.innerHTML = '';
      }
      if (elements.storiesList) {
        elements.storiesList.innerHTML = '';
      }
      elements.storiesGlance?.classList.remove('hidden');
    }

    if (elements.emptyContainer) {
      elements.emptyContainer.classList.toggle('hidden', filteredStories.length > 0);
    }
  }

  function renderStoryCard(story: Story, index: number): string {
    const source = getStorySource(story);
    const discussionUrl = getDiscussionUrl(story);
    const safeDiscussionUrl = safeExternalUrl(discussionUrl);
    const safeArticleUrl = safeExternalUrl(story.u);
    const safeTitle = escapeHtml(story.t);
    const safeAuthor = escapeHtml(story.a);
    const safeAttribution = escapeHtml(getStoryAttribution(story));
    const safeBody = story.b ? escapeHtml(story.b) : '';
    const scoreFormatted = story.s >= 1000 ? `${(story.s / 1000).toFixed(1)}k` : story.s.toString();
    const commentsFormatted = story.c >= 1000 ? `${(story.c / 1000).toFixed(1)}k` : story.c.toString();
    const platformName = source === 'reddit' ? 'Reddit' : source === 'hn' ? 'Hacker News' : 'RSS';
    const readTime = story.b ? Math.max(1, Math.ceil(story.b.split(' ').length / 200)) : null;
    const readTimeLabel = readTime ? `${readTime} min read` : null;
    const isBookmarked = state.bookmarks.has(story.i);
    const platformIcon = source === 'reddit'
      ? '<svg class="w-3.5 h-3.5 text-[#FF4500]" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/></svg>'
      : source === 'hn'
        ? '<svg class="w-3.5 h-3.5 text-[#FF6600]" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0L1.5 6v12L12 24l10.5-6V6L12 0zm0 2.3l8.3 5v9.4l-8.3 5-8.3-5V7.3l8.3-5z"/></svg>'
        : '<svg class="w-3.5 h-3.5 text-blue-500" viewBox="0 0 24 24" fill="currentColor"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>';

    return `
      <article
        class="story-card-enter group relative bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-3 sm:p-4 transition-all duration-300 hover:border-amber-500/40 hover:shadow-[0_16px_40px_rgba(245,158,11,0.12)] flex flex-col"
        style="animation-delay: ${index * 40}ms"
        aria-label="${safeTitle}"
      >
        <a href="${safeArticleUrl}" target="_blank" rel="noopener noreferrer" aria-label="Read article: ${safeTitle}" class="block cursor-pointer flex-1">
          <div class="flex items-start gap-2.5 mb-2">
            <div class="flex-shrink-0 mt-0.5" aria-label="${platformName}" role="img">
              ${source === 'reddit'
                ? '<svg class="w-4 h-4 text-[#FF4500] opacity-90" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/></svg>'
                : source === 'hn'
                  ? '<svg class="w-4 h-4 text-[#FF6600] opacity-90" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0L1.5 6v12L12 24l10.5-6V6L12 0zm0 2.3l8.3 5v9.4l-8.3 5-8.3-5V7.3l8.3-5z"/></svg>'
                  : '<svg class="w-4 h-4 text-blue-500 opacity-90" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>'
              }
            </div>
            <h3 class="text-base font-bold leading-snug text-slate-900 dark:text-slate-100 line-clamp-2 group-hover:text-amber-700 dark:group-hover:text-amber-200 transition-colors duration-200">
              ${safeTitle}
            </h3>
          </div>
          ${safeBody ? `<p class="text-sm text-slate-600 dark:text-slate-400 line-clamp-3 mt-2">${safeBody}</p>` : ''}
        </a>

        <div class="mt-3 pt-3 border-t border-slate-200 dark:border-slate-800/60">
          <div class="flex items-center gap-2 text-xs text-slate-600 dark:text-slate-400 mb-2">
            <span class="inline-flex items-center gap-1 truncate max-w-[130px] sm:max-w-[150px]" title="${story.a}">
              <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A10.97 10.97 0 0112 15.5c2.6 0 4.99.9 6.879 2.304M15 9a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span class="truncate">${safeAuthor}</span>
            </span>
            <span class="inline-flex items-center gap-1 truncate max-w-[110px] sm:max-w-[130px]" title="${safeAttribution}">
              <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h9l7 7v9a2 2 0 01-2 2z" />
              </svg>
              <span class="truncate">${safeAttribution}</span>
            </span>
            <span class="font-mono-data flex items-center gap-0.5" aria-label="Score: ${story.s}">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
              </svg>
              ${scoreFormatted}
            </span>
            ${readTimeLabel ? `<span class="text-slate-400 dark:text-slate-500">· ${readTimeLabel}</span>` : ''}
          </div>
          <div class="flex items-center gap-2">
            <a
              href="${safeDiscussionUrl}"
              target="_blank"
              rel="noopener noreferrer"
              data-comment-link="true"
              data-source="${source}"
              data-story-url="${safeArticleUrl}"
              data-discussion-url="${safeDiscussionUrl}"
              class="flex-1 inline-flex items-center justify-center gap-2 px-3 py-2 rounded-lg text-xs font-medium bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 border border-slate-200 dark:border-slate-700 hover:bg-amber-50 dark:hover:bg-amber-500/10 hover:text-amber-700 dark:hover:text-amber-300 hover:border-amber-300 dark:hover:border-amber-500/40 transition-all duration-200 cursor-pointer"
              aria-label="${commentsFormatted} comments on ${platformName}, opens in new tab"
            >
              ${platformIcon}
              <span>${commentsFormatted} comments on ${platformName}</span>
            </a>
            <button
              type="button"
              class="bookmark-btn p-2 rounded-lg text-slate-400 hover:text-primary-500 dark:hover:text-primary-400 transition-colors"
              data-story-id="${story.i}"
              aria-label="${isBookmarked ? 'Remove bookmark' : 'Bookmark this story'}"
              aria-pressed="${isBookmarked}"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="${isBookmarked ? 'currentColor' : 'none'}" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-4-7 4V5z" />
              </svg>
            </button>
          </div>
        </div>
      </article>
    `;
  }

  function renderStoryList(stories: Story[]): string {
    return `
      <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl overflow-hidden">
        <div class="sm:hidden divide-y divide-slate-200 dark:divide-slate-800">
          ${stories.map(story => {
            const source = getStorySource(story);
            const discussionUrl = getDiscussionUrl(story);
            const safeDiscussionUrl = safeExternalUrl(discussionUrl);
            const safeArticleUrl = safeExternalUrl(story.u);
            const safeTitle = escapeHtml(story.t);
            const safeAuthor = escapeHtml(story.a);
            const safeAttribution = escapeHtml(getStoryAttribution(story));
            const safeBody = story.b ? escapeHtml(story.b) : '';
            const scoreFormatted = story.s >= 1000 ? `${(story.s / 1000).toFixed(1)}k` : story.s.toString();
            const commentsFormatted = story.c >= 1000 ? `${(story.c / 1000).toFixed(1)}k` : story.c.toString();
            const platformName = source === 'reddit' ? 'Reddit' : source === 'hn' ? 'Hacker News' : 'RSS';

            return `
              <article class="p-4" aria-label="${safeTitle}">
                <a href="${safeArticleUrl}" target="_blank" rel="noopener noreferrer" aria-label="Read article: ${safeTitle}" class="block cursor-pointer">
                  <div class="flex items-start gap-2.5 mb-2">
                    <div class="flex-shrink-0 mt-0.5" aria-label="${platformName}" role="img">
                      ${source === 'reddit'
                        ? '<svg class="w-4 h-4 text-[#FF4500] opacity-80" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/></svg>'
                        : source === 'hn'
