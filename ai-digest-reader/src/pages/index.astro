---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Controls from '../components/Controls.astro';
import type { Story, DigestSummary as DigestSummaryType, ViewMode, Source } from '../types';

interface Props {}

const { } = Astro.props;
---

<Base title="AI Digest - Your Daily AI News">
  <Header />

  <main class="max-w-4xl mx-auto px-2 sm:px-3 py-2 sm:py-3">
    <div id="summary-container"></div>
    
    <div id="controls-container" class="mb-3">
      <Controls />
    </div>

    <div id="pull-refresh-hint" class="flex items-center justify-center gap-2 mb-3 text-xs text-slate-400 dark:text-slate-500 opacity-0 transition-opacity duration-300">
      <svg class="w-3 h-3 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
      <span>Pull down to refresh</span>
    </div>

    <div id="loading-container" class="hidden">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3" id="loading-cards">
        {[...Array(6)].map(() => (
          <div class="backdrop-blur-md bg-white/70 dark:bg-slate-800/60 border border-white/20 dark:border-slate-700/50 rounded-xl p-4 animate-pulse">
            <div class="flex items-center gap-2 mb-2">
              <div class="h-5 w-12 bg-slate-200 dark:bg-slate-700 rounded"></div>
            </div>
            <div class="space-y-1.5 mb-3">
              <div class="h-4 bg-slate-200 dark:bg-slate-700 rounded w-full"></div>
              <div class="h-4 bg-slate-200 dark:bg-slate-700 rounded w-2/3"></div>
            </div>
            <div class="flex items-center justify-between">
              <div class="h-3 bg-slate-200 dark:bg-slate-700 rounded w-20"></div>
              <div class="flex items-center gap-2">
                <div class="h-3 w-6 bg-slate-200 dark:bg-slate-700 rounded"></div>
                <div class="h-3 w-6 bg-slate-200 dark:bg-slate-700 rounded"></div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div id="error-container" class="hidden">
      <div class="backdrop-blur-md bg-white/70 dark:bg-slate-800/60 border border-red-200 dark:border-red-800/50 rounded-2xl p-8 text-center">
        <svg class="w-12 h-12 mx-auto mb-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <h3 class="text-lg font-medium text-slate-900 dark:text-white mb-2">Failed to load stories</h3>
        <p id="error-message" class="text-slate-500 dark:text-slate-400 mb-4">Something went wrong</p>
        <button
          id="retry-button"
          class="inline-flex items-center gap-2 px-4 py-2 bg-primary-500 hover:bg-primary-600 text-white rounded-lg transition-colors duration-200"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
          Try Again
        </button>
      </div>
    </div>

    <div id="stories-container" class="transition-opacity duration-300">
      <div id="stories-cards" class="view-content"></div>
      <div id="stories-list" class="view-content hidden"></div>
      <div id="stories-glance" class="view-content hidden"></div>
    </div>

    <div id="empty-container" class="hidden">
      <div class="backdrop-blur-md bg-white/70 dark:bg-slate-800/60 border border-white/20 dark:border-slate-700/50 rounded-2xl p-8 text-center">
        <svg class="w-12 h-12 mx-auto mb-4 text-slate-300 dark:text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
        </svg>
        <h3 class="text-lg font-medium text-slate-900 dark:text-white mb-2">No stories found</h3>
        <p class="text-slate-500 dark:text-slate-400">Try adjusting your filters or check back later</p>
      </div>
    </div>
  </main>
</Base>

<script>
  import type { Story, Digest, DigestSummary as DigestSummaryType, ViewMode, Source, MustReadItem, FullBriefSection } from '../types';
  import StoryCard from '../components/StoryCard.astro';
  import StoryList from '../components/StoryList.astro';
  import StoryGlance from '../components/StoryGlance.astro';

  interface AppState {
    stories: Story[];
    filteredStories: Story[];
    summary: DigestSummaryType | null;
    viewMode: ViewMode;
    source: Source;
    isLoading: boolean;
    error: string | null;
  }

  const state: AppState = {
    stories: [],
    filteredStories: [],
    summary: null,
    viewMode: 'cards',
    source: 'all',
    isLoading: true,
    error: null,
  };

  const elements = {
    loadingContainer: document.getElementById('loading-container'),
    errorContainer: document.getElementById('error-container'),
    errorMessage: document.getElementById('error-message'),
    retryButton: document.getElementById('retry-button'),
    storiesContainer: document.getElementById('stories-container'),
    emptyContainer: document.getElementById('empty-container'),
    storiesCards: document.getElementById('stories-cards'),
    storiesList: document.getElementById('stories-list'),
    storiesGlance: document.getElementById('stories-glance'),
    pullRefreshHint: document.getElementById('pull-refresh-hint'),
    summaryContainer: document.getElementById('summary-container'),
  };

  function getSourceCounts(stories: Story[]): { reddit: number; hn: number; total: number } {
    const reddit = stories.filter(s => s.i.startsWith('rd-')).length;
    const hn = stories.filter(s => s.i.startsWith('hn-')).length;
    return { reddit, hn, total: stories.length };
  }

  function filterStories(stories: Story[], source: Source): Story[] {
    if (source === 'all') return stories;
    return stories.filter(story => {
      const storySource = story.i.startsWith('rd-') ? 'reddit' : 'hn';
      return storySource === source;
    });
  }

  function renderStories() {
    if (!elements.storiesCards || !elements.storiesList || !elements.storiesGlance) return;

    const { filteredStories, viewMode } = state;

    elements.storiesCards.innerHTML = filteredStories.length > 0
      ? `<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">${
          filteredStories.map(story => renderStoryCard(story)).join('')
        }</div>`
      : '';

    elements.storiesList.innerHTML = filteredStories.length > 0
      ? renderStoryList(filteredStories)
      : '';

    elements.storiesGlance.innerHTML = filteredStories.length > 0
      ? renderStoryGlance(filteredStories)
      : '';

    [elements.storiesCards, elements.storiesList, elements.storiesGlance].forEach(el => {
      el?.classList.add('hidden');
    });

    if (viewMode === 'cards') {
      elements.storiesCards?.classList.remove('hidden');
    } else if (viewMode === 'list') {
      elements.storiesList?.classList.remove('hidden');
    } else {
      elements.storiesGlance?.classList.remove('hidden');
    }

    if (elements.emptyContainer) {
      elements.emptyContainer.classList.toggle('hidden', filteredStories.length > 0);
    }
  }

  function renderStoryCard(story: Story): string {
    const source = story.i.startsWith('rd-') ? 'reddit' : 'hn';
    const scoreFormatted = story.s >= 1000 ? `${(story.s / 1000).toFixed(1)}k` : story.s.toString();
    const commentsFormatted = story.c >= 1000 ? `${(story.c / 1000).toFixed(1)}k` : story.c.toString();

    return `
      <article class="group relative backdrop-blur-md bg-white/70 dark:bg-slate-800/60 border border-white/20 dark:border-slate-700/50 rounded-xl p-3 sm:p-4 transition-all duration-300 hover:shadow-md hover:-translate-y-0.5">
        <a href="${story.u}" target="_blank" rel="noopener noreferrer" class="block">
          <div class="flex items-start gap-2.5 mb-2">
            <div class="flex-shrink-0 mt-0.5" title="${source === 'reddit' ? 'Reddit' : 'Hacker News'}">
              ${source === 'reddit'
                ? '<svg class="w-4 h-4 text-[#FF4500] opacity-90" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/></svg>'
                : '<svg class="w-4 h-4 text-[#FF6600] opacity-90" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0L1.5 6v12L12 24l10.5-6V6L12 0zm0 2.3l8.3 5v9.4l-8.3 5-8.3-5V7.3l8.3-5z"/></svg>'
              }
            </div>
            <h3 class="text-sm sm:text-base font-medium text-slate-900 dark:text-white line-clamp-2 group-hover:text-primary-500 dark:group-hover:text-primary-400 transition-colors duration-200">
              ${story.t}
            </h3>
          </div>
          <div class="flex items-center justify-between text-xs text-slate-500 dark:text-slate-400">
            <span class="truncate max-w-[100px] sm:max-w-[120px]" title="${story.a}">
              ${story.a}
            </span>
            <div class="flex items-center gap-2 sm:gap-3">
              <span class="flex items-center gap-0.5" title="Score">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                </svg>
                ${scoreFormatted}
              </span>
              <span class="flex items-center gap-0.5" title="Comments">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                </svg>
                ${commentsFormatted}
              </span>
            </div>
          </div>
        </a>
      </article>
    `;
  }

  function renderStoryList(stories: Story[]): string {
    return `
      <div class="backdrop-blur-md bg-white/70 dark:bg-slate-800/60 border border-white/20 dark:border-slate-700/50 rounded-2xl overflow-hidden">
        <div class="overflow-x-auto -mx-4 px-4 sm:mx-0 sm:px-0">
          <table class="w-full min-w-[640px]">
            <thead>
              <tr class="border-b border-slate-200/50 dark:border-slate-700/50">
                <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Title</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider hidden sm:table-cell">Author</th>
                <th class="px-4 py-3 text-right text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Score</th>
                <th class="px-4 py-3 text-right text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Comments</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200/50 dark:divide-slate-700/50">
              ${stories.map(story => {
                const source = story.i.startsWith('rd-') ? 'reddit' : 'hn';
                const scoreFormatted = story.s >= 1000 ? `${(story.s / 1000).toFixed(1)}k` : story.s.toString();
                const commentsFormatted = story.c >= 1000 ? `${(story.c / 1000).toFixed(1)}k` : story.c.toString();
                return `
                  <tr class="hover:bg-slate-100/50 dark:bg-slate-700/30 transition-colors duration-150 group/row">
                    <td class="px-4 py-3">
                      <div class="flex items-start gap-2.5">
                        <div class="flex-shrink-0 mt-0.5" title="${source === 'reddit' ? 'Reddit' : 'Hacker News'}">
                          ${source === 'reddit'
                            ? '<svg class="w-4 h-4 text-[#FF4500] opacity-80" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/></svg>'
                            : '<svg class="w-4 h-4 text-[#FF6600] opacity-80" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0L1.5 6v12L12 24l10.5-6V6L12 0zm0 2.3l8.3 5v9.4l-8.3 5-8.3-5V7.3l8.3-5z"/></svg>'}
                        </div>
                        <a href="${story.u}" target="_blank" rel="noopener noreferrer"
                          class="text-slate-900 dark:text-white group-hover/row:text-primary-500 dark:group-hover/row:text-primary-400 transition-colors duration-150 line-clamp-2">
                          ${story.t}
                        </a>
                      </div>
                    </td>
                    <td class="px-4 py-3 text-sm text-slate-500 dark:text-slate-400 hidden sm:table-cell truncate max-w-[150px]" title="${story.a}">
                      ${story.a}
                    </td>
                    <td class="px-4 py-3 text-right text-sm text-slate-600 dark:text-slate-300 tabular-nums">
                      ${scoreFormatted}
                    </td>
                    <td class="px-4 py-3 text-right text-sm text-slate-500 dark:text-slate-400 tabular-nums">
                      ${commentsFormatted}
                    </td>
                  </tr>
                `;
              }).join('')}
            </tbody>
          </table>
        </div>
      </div>
    `;
  }

  function renderStoryGlance(stories: Story[]): string {
    return `
      <div class="flex flex-wrap gap-2">
        ${stories.map(story => {
          const source = story.i.startsWith('rd-') ? 'reddit' : 'hn';
          return `
            <a href="${story.u}" target="_blank" rel="noopener noreferrer"
              class="group inline-flex items-center gap-2 backdrop-blur-sm bg-white/50 dark:bg-slate-800/40 border border-white/20 dark:border-slate-700/30 rounded-full px-3 py-1.5 text-sm text-slate-700 dark:text-slate-300 hover:bg-white/80 dark:hover:bg-slate-700/60 hover:border-primary-300 dark:hover:border-primary-600/50 transition-all duration-150">
              <span class="flex-shrink-0 ${source === 'reddit' ? 'text-orange-500' : 'text-orange-600 dark:text-orange-400'}">
                ${source === 'reddit'
                  ? '<svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/></svg>'
                  : '<svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0L1.5 6v12L12 24l10.5-6V6L12 0zm0 2.3l8.3 5v9.4l-8.3 5-8.3-5V7.3l8.3-5z"/></svg>'
                }
              </span>
              <span class="truncate max-w-[200px] sm:max-w-[300px] group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
                ${story.t}
              </span>
              <span class="flex-shrink-0 text-slate-400 dark:text-slate-500 tabular-nums text-xs">
                ${story.s}
              </span>
            </a>
          `;
        }).join('')}
      </div>
    `;
  }

  function updateSourceFilter() {
    const counts = getSourceCounts(state.stories);
    const counts_els = document.querySelectorAll('.source-badge .count');
    if (counts_els.length >= 3) {
      counts_els[0].textContent = counts.total.toString();
      counts_els[1].textContent = counts.reddit.toString();
      counts_els[2].textContent = counts.hn.toString();
    }
  }

  function showLoading() {
    state.isLoading = true;
    elements.loadingContainer?.classList.remove('hidden');
    elements.errorContainer?.classList.add('hidden');
    elements.storiesContainer?.classList.add('opacity-50', 'pointer-events-none');
  }

  function hideLoading() {
    state.isLoading = false;
    elements.loadingContainer?.classList.add('hidden');
    elements.storiesContainer?.classList.remove('opacity-50', 'pointer-events-none');
    
    if (elements.summaryContainer && state.summary) {
      elements.summaryContainer.innerHTML = renderDigestSummary(state.summary, state.stories);
      initSummaryTabs();
    }
  }

  function escapeHtml(input: string): string {
    return input
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');
  }

  function getStoryUrl(stories: Story[], id: string): string {
    const story = stories.find(s => s.i === id);
    return story?.u || '#';
  }

  function renderDigestSummary(summary: DigestSummaryType, stories: Story[]): string {
    const themesHtml = summary.structured.themes.map((t: string) =>
      '<span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-primary-100 dark:bg-primary-900/50 text-primary-700 dark:text-primary-300">' + escapeHtml(t) + '</span>'
    ).join('');

    const breakingHtml = summary.structured.breaking
      ? '<div class="p-2.5 bg-red-50 dark:bg-red-900/20 rounded-lg border border-red-200 dark:border-red-800/50"><h4 class="text-xs font-semibold text-red-600 dark:text-red-400 uppercase tracking-wider mb-1 flex items-center gap-1"><svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>Breaking</h4><p class="text-sm text-red-800 dark:text-red-300">' + escapeHtml(summary.structured.breaking) + '</p></div>'
      : '';

    const mustReadHtml = summary.structured.mustRead.map((item: MustReadItem, idx: number) =>
      '<a href="' + getStoryUrl(stories, item.id) + '" target="_blank" rel="noopener noreferrer" class="flex items-start gap-3 group cursor-pointer p-2.5 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700/30 transition-colors duration-150">' +
        '<span class="flex-shrink-0 w-6 h-6 rounded-full bg-primary-500 dark:bg-primary-600 text-white text-xs font-bold flex items-center justify-center">' + (idx + 1) + '</span>' +
        '<div class="flex-1 min-w-0">' +
          '<p class="text-sm font-medium text-slate-900 dark:text-slate-100 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors duration-150">' + escapeHtml(item.title) + '</p>' +
          '<p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">' + escapeHtml(item.reason) + '</p>' +
        '</div>' +
        '<svg class="flex-shrink-0 w-4 h-4 text-slate-400 group-hover:text-primary-500 transition-colors duration-150 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>' +
      '</a>'
    ).join('');
    
    return '<div class="digest-summary bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl p-4 mb-4 shadow-sm">' +
      '<div class="flex items-center justify-between mb-3">' +
        '<div class="flex items-center gap-2">' +
          '<div class="w-8 h-8 rounded-lg bg-gradient-to-br from-primary-500 to-primary-600 flex items-center justify-center">' +
            '<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>' +
          '</div>' +
          '<span class="font-bold text-base text-slate-900 dark:text-white">AI Summary</span>' +
        '</div>' +
        '<span class="text-xs text-slate-400 dark:text-slate-500 text-right leading-tight">AI-generated<br>verify before sharing</span>' +
      '</div>' +
      '<div class="swipe-track-outer" id="swipe-track-outer">' +
        '<div class="swipe-track" id="swipe-track">' +
          '<div class="swipe-card">' +
            '<div class="card-snippet">' +
              '<p class="text-slate-700 dark:text-slate-200 text-sm leading-relaxed font-medium">' + escapeHtml(summary.simple) + '</p>' +
            '</div>' +
            '<div class="card-snippet-fade"></div>' +
            '<button type="button" class="card-view-more mt-2 text-sm font-medium text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300">View more ↓</button>' +
          '</div>' +
          '<div class="swipe-card">' +
            '<div class="card-snippet">' +
              '<div class="space-y-3">' +
                '<div><h4 class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">Key Themes</h4><div class="flex flex-wrap gap-2">' + themesHtml + '</div></div>' +
                breakingHtml +
                '<div><h4 class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">Must Read</h4><div class="space-y-1 bg-slate-50 dark:bg-slate-800/50 rounded-lg p-1">' + mustReadHtml + '</div></div>' +
              '</div>' +
            '</div>' +
            '<div class="card-snippet-fade"></div>' +
            '<button type="button" class="card-view-more mt-2 text-sm font-medium text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300">View more ↓</button>' +
          '</div>' +
          '<div class="swipe-card">' +
            '<div class="card-snippet">' +
              '<div id="full-brief-content" class="digest-prose text-sm text-slate-700 dark:text-slate-200 leading-relaxed"></div>' +
            '</div>' +
            '<div class="card-snippet-fade"></div>' +
            '<button type="button" class="card-view-more mt-2 text-sm font-medium text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300">View more ↓</button>' +
          '</div>' +
        '</div>' +
      '</div>' +
      '<div class="mt-3 flex items-center justify-between gap-3">' +
        '<button type="button" id="summary-prev-btn" class="h-8 w-8 rounded-full border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 disabled:opacity-40 disabled:cursor-not-allowed hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors" aria-label="Previous summary card">' +
          '<svg class="mx-auto h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>' +
        '</button>' +
        '<div class="flex items-center gap-2" aria-label="Summary cards">' +
          '<button type="button" class="swipe-dot active" data-index="0" aria-label="Show Simple summary"></button>' +
          '<button type="button" class="swipe-dot" data-index="1" aria-label="Show Structured summary"></button>' +
          '<button type="button" class="swipe-dot" data-index="2" aria-label="Show Full Brief summary"></button>' +
        '</div>' +
        '<button type="button" id="summary-next-btn" class="h-8 w-8 rounded-full border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 disabled:opacity-40 disabled:cursor-not-allowed hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors" aria-label="Next summary card">' +
          '<svg class="mx-auto h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>' +
        '</button>' +
      '</div>' +
    '</div>';
  }

  function initSummaryTabs() {
    const outer = document.getElementById('swipe-track-outer');
    const track = document.getElementById('swipe-track') as HTMLElement | null;
    const prevBtn = document.getElementById('summary-prev-btn') as HTMLButtonElement | null;
    const nextBtn = document.getElementById('summary-next-btn') as HTMLButtonElement | null;
    const dots = document.querySelectorAll('.swipe-dot');
    const fullBriefContent = document.getElementById('full-brief-content');

    if (fullBriefContent) {
      const summaryData = state.summary;
      if (summaryData) {
        const fb = summaryData.fullBrief;
        let html = '<p class="mb-3 text-sm leading-relaxed">' + escapeHtml(fb.intro) + '</p>';
        fb.sections.forEach((sec: FullBriefSection) => {
          html += '<h3 class="text-base font-semibold text-slate-800 dark:text-slate-100 mt-4 mb-2">' + escapeHtml(sec.heading) + '</h3>';
          html += '<p class="mb-2 text-sm leading-relaxed">' + escapeHtml(sec.body) + '</p>';
        });
        html += '<p class="mt-3 text-xs text-slate-500 dark:text-slate-400 italic">' + escapeHtml(fb.closing) + '</p>';
        fullBriefContent.innerHTML = html;
      }
    }

    if (!outer || !track || !prevBtn || !nextBtn || dots.length === 0) return;

    let current = 0;
    const total = 3;
    const cards = Array.from(track.querySelectorAll('.swipe-card')) as HTMLElement[];

    function isInteractiveTarget(target: EventTarget | null): boolean {
      const element = target as HTMLElement | null;
      return Boolean(element?.closest('button, a'));
    }

    function goTo(index: number) {
      current = Math.max(0, Math.min(total - 1, index));
      track!.style.transform = 'translateX(-' + (current * 100) + '%)';
      dots.forEach((dot, idx) => {
        dot.classList.toggle('active', idx === current);
      });
      prevBtn!.disabled = current === 0;
      nextBtn!.disabled = current === total - 1;
      const activeCard = cards[current];
      if (activeCard && outer) {
        // Use offsetHeight to get the current visible height including the snippet's max-height constraint
        outer.style.height = activeCard.offsetHeight + 'px';
      }
    }

    prevBtn.addEventListener('click', () => goTo(current - 1));
    nextBtn.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => goTo(index));
    });

    let touchStartX = 0;
    outer.addEventListener('touchstart', (event) => {
      if (isInteractiveTarget(event.target)) {
        touchStartX = 0;
        return;
      }
      touchStartX = event.changedTouches[0].clientX;
    }, { passive: true });

    outer.addEventListener('touchend', (event) => {
      if (touchStartX === 0) return;
      const dx = event.changedTouches[0].clientX - touchStartX;
      touchStartX = 0;
      if (Math.abs(dx) > 40) {
        goTo(dx < 0 ? current + 1 : current - 1);
      }
    }, { passive: true });

    let dragging = false;
    let pointerStartX = 0;

    outer.addEventListener('pointerdown', (event) => {
      if (event.button !== 0 || isInteractiveTarget(event.target)) return;
      dragging = true;
      pointerStartX = event.clientX;
      (event.currentTarget as HTMLElement).setPointerCapture(event.pointerId);
    });

    outer.addEventListener('pointermove', () => {
      if (!dragging) return;
    });

    outer.addEventListener('pointerup', (event) => {
      if (!dragging) return;
      dragging = false;
      const dx = event.clientX - pointerStartX;
      if (Math.abs(dx) > 40) {
        goTo(dx < 0 ? current + 1 : current - 1);
      }
    });

    outer.addEventListener('pointercancel', () => {
      dragging = false;
    });

    const viewMoreButtons = Array.from(document.querySelectorAll('.card-view-more')) as HTMLButtonElement[];
    const snippets = Array.from(document.querySelectorAll('.card-snippet')) as HTMLElement[];
    const fades = Array.from(document.querySelectorAll('.card-snippet-fade')) as HTMLElement[];
    function setCardExpanded(cardIndex: number, expanded: boolean) {
      const snippet = snippets[cardIndex];
      const fade = fades[cardIndex];
      const btn = viewMoreButtons[cardIndex];
      if (!snippet || !fade || !btn) return;

      snippet.classList.toggle('expanded', expanded);
      snippet.style.maxHeight = expanded ? snippet.scrollHeight + 'px' : '9rem';
      fade.style.opacity = (expanded || snippet.scrollHeight <= 144) ? '0' : '1';
      btn.setAttribute('aria-expanded', expanded ? 'true' : 'false');
      btn.textContent = expanded ? 'Show less ↑' : 'View more ↓';

      if (cardIndex === current) {
        const activeCard = cards[current];
        if (activeCard && outer) {
          // Calculate target height: card height - current snippet height + target snippet height
          const currentSnippetHeight = snippet.offsetHeight;
          const targetSnippetHeight = expanded ? snippet.scrollHeight : Math.min(snippet.scrollHeight, 144);
          const currentCardHeight = activeCard.offsetHeight;
          const targetCardHeight = currentCardHeight - currentSnippetHeight + targetSnippetHeight;
          
          outer.style.height = targetCardHeight + 'px';
        }
      }
    }

    viewMoreButtons.forEach((btn, index) => {
      setCardExpanded(index, false);
      btn.addEventListener('click', () => {
        const isExpanded = snippets[index]?.classList.contains('expanded') ?? false;
        setCardExpanded(index, !isExpanded);
      });
    });

    goTo(0);
  }

  function showError(message: string) {
    state.error = message;
    hideLoading();
    elements.errorContainer?.classList.remove('hidden');
    if (elements.errorMessage) {
      elements.errorMessage.textContent = message;
    }
  }

  async function fetchDigest() {
    showLoading();
    try {
      const response = await fetch('/data/digest.json');
      if (!response.ok) {
        throw new Error(`Failed to fetch digest: ${response.status}`);
      }
      const data: Digest = await response.json();

      state.stories = [...data.r, ...data.h];
      state.filteredStories = filterStories(state.stories, state.source);
      state.summary = data.summary || null;

      updateSourceFilter();
      renderStories();
      hideLoading();
    } catch (error) {
      console.error('Error fetching digest:', error);
      showError(error instanceof Error ? error.message : 'Failed to load stories');
    }
  }

  function handleViewChange(event: Event) {
    const customEvent = event as CustomEvent<{ mode: ViewMode }>;
    state.viewMode = customEvent.detail.mode;

    if (elements.storiesContainer) {
      elements.storiesContainer.classList.add('opacity-0');
      setTimeout(() => {
        renderStories();
        elements.storiesContainer?.classList.remove('opacity-0');
      }, 150);
    } else {
      renderStories();
    }
  }

  function handleSourceChange(event: Event) {
    const customEvent = event as CustomEvent<{ source: Source }>;
    state.source = customEvent.detail.source;
    state.filteredStories = filterStories(state.stories, state.source);
    renderStories();
  }

  document.addEventListener('viewchange', handleViewChange);
  document.addEventListener('sourcechange', handleSourceChange);

  elements.retryButton?.addEventListener('click', fetchDigest);

  let touchStartY = 0;
  let touchEndY = 0;

  document.addEventListener('touchstart', (e) => {
    if (window.scrollY === 0) {
      touchStartY = e.changedTouches[0].screenY;
    }
  }, { passive: true });

  document.addEventListener('touchend', (e) => {
    touchEndY = e.changedTouches[0].screenY;
    const pullDistance = touchEndY - touchStartY;

    if (pullDistance > 80 && window.scrollY === 0) {
      if (elements.pullRefreshHint) {
        elements.pullRefreshHint.style.opacity = '0';
      }
      fetchDigest();
    }
  }, { passive: true });

  if (window.scrollY === 0) {
    if (elements.pullRefreshHint) {
      elements.pullRefreshHint.style.opacity = '1';
      setTimeout(() => {
        if (elements.pullRefreshHint) {
          elements.pullRefreshHint.style.opacity = '0';
        }
      }, 3000);
    }
  }

  fetchDigest();
</script>

