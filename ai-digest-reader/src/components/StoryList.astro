---
import type { Story } from '../types';

interface Props {
  stories: Story[];
}

const { stories } = Astro.props;

function getSource(id: string): 'reddit' | 'hn' {
  return id.startsWith('rd-') ? 'reddit' : 'hn';
}

function formatScore(score: number): string {
  if (score >= 1000) {
    return `${(score / 1000).toFixed(1)}k`;
  }
  return score.toString();
}

function formatComments(comments: number): string {
  if (comments >= 1000) {
    return `${(comments / 1000).toFixed(1)}k`;
  }
  return comments.toString();
}


---

<div class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden">
  <div class="sm:hidden divide-y divide-slate-800">
    {stories.map((story) => {
      const source = getSource(story.i);
      const discussionUrl = story.p || story.u;
      return (
        <article class="p-4">
          <a href={story.u} target="_blank" rel="noopener noreferrer" class="block min-h-[44px] cursor-pointer">
            <div class="flex items-start gap-2 mb-1.5">
              <div class="flex-shrink-0 mt-0.5" title={source === 'reddit' ? 'Reddit' : 'Hacker News'}>
                {source === 'reddit' ? (
                  <svg class="w-4 h-4 text-[#FF4500] opacity-80" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/>
                  </svg>
                ) : (
                  <svg class="w-4 h-4 text-[#FF6600] opacity-80" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0L1.5 6v12L12 24l10.5-6V6L12 0zm0 2.3l8.3 5v9.4l-8.3 5-8.3-5V7.3l8.3-5z"/>
                  </svg>
                )}
              </div>
              <h3 class="text-sm font-bold text-slate-100 line-clamp-2 leading-snug">
                {story.t}
              </h3>
            </div>
            {story.b && (
              <p class="text-xs text-slate-400 line-clamp-3 ml-6">
                {story.b}
              </p>
            )}
          </a>
          <div class="mt-3 pt-3 border-t border-slate-800/50 flex items-center justify-between gap-2">
            <div class="flex items-center gap-2 text-xs text-slate-500">
              <span class="inline-flex items-center gap-1 truncate max-w-[120px]" title={story.a}>
                <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A10.97 10.97 0 0112 15.5c2.6 0 4.99.9 6.879 2.304M15 9a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span class="truncate">{story.a}</span>
              </span>
              <span class="font-mono-data">↑ {formatScore(story.s)}</span>
            </div>
            <a
              href={discussionUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium bg-slate-800 text-slate-300 border border-slate-700 hover:bg-amber-500/10 hover:text-amber-300 hover:border-amber-500/50 transition-all duration-200 cursor-pointer"
              title="Join the discussion"
            >
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
              </svg>
              {formatComments(story.c)} comments
            </a>
          </div>
        </article>
      );
    })}
  </div>

  <table class="hidden sm:table w-full min-w-[600px]">
    <tbody class="divide-y divide-slate-800">
      {stories.map((story) => {
        const source = getSource(story.i);
        const discussionUrl = story.p || story.u;
        return (
          <tr class="hover:bg-slate-800/70 transition-colors duration-150 group/row">
            <td class="px-3 py-2.5">
              <div class="flex items-start gap-2">
                <div class="flex-shrink-0 mt-0.5" title={source === 'reddit' ? 'Reddit' : 'Hacker News'}>
                  {source === 'reddit' ? (
                    <svg class="w-4 h-4 text-[#FF4500] opacity-80" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/>
                    </svg>
                  ) : (
                    <svg class="w-4 h-4 text-[#FF6600] opacity-80" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 0L1.5 6v12L12 24l10.5-6V6L12 0zm0 2.3l8.3 5v9.4l-8.3 5-8.3-5V7.3l8.3-5z"/>
                    </svg>
                  )}
                </div>
                <div>
                  <a 
                    href={story.u}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-sm font-bold text-slate-100 group-hover/row:text-amber-200 transition-colors duration-150 line-clamp-2 cursor-pointer"
                  >
                    {story.t}
                  </a>
                  {story.b && (
                    <p class="text-xs text-slate-400 line-clamp-2 mt-1">
                      {story.b}
                    </p>
                  )}
                </div>
              </div>
            </td>
            <td class="px-3 py-2.5 text-xs text-slate-400 hidden sm:table-cell max-w-[140px]" title={story.a}>
              <span class="inline-flex items-center gap-1 max-w-full">
                <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A10.97 10.97 0 0112 15.5c2.6 0 4.99.9 6.879 2.304M15 9a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span class="truncate">{story.a}</span>
              </span>
            </td>
            <td class="px-3 py-2.5 text-right text-xs text-slate-300 tabular-nums font-mono-data">
              {formatScore(story.s)}
            </td>
            <td class="px-3 py-3 text-right">
              <a
                href={discussionUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-slate-800 text-slate-400 border border-slate-700 hover:bg-amber-500/10 hover:text-amber-300 hover:border-amber-500/50 transition-all duration-200 cursor-pointer whitespace-nowrap"
                title="Join the discussion"
              >
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                </svg>
                {formatComments(story.c)}
              </a>
            </td>
          </tr>
        );
      })}
    </tbody>
  </table>
</div>
