---
const sources = [
  { id: 'all', label: 'All' },
  { id: 'reddit', label: 'Reddit' },
  { id: 'hn', label: 'HackerNews' },
];
---

<div class="flex flex-col gap-2 text-xs">
  <!-- View mode toggle -->
  <div class="flex items-center gap-1 p-0.5 rounded-lg bg-white/30 dark:bg-slate-800/50" role="group" aria-label="View mode">
    <button type="button" data-view="cards" aria-pressed="true" class="view-btn px-3 py-2 rounded-md transition-all duration-150 flex items-center justify-center gap-1.5 flex-1">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <rect x="3" y="3" width="7" height="7" rx="1" />
        <rect x="14" y="3" width="7" height="7" rx="1" />
        <rect x="3" y="14" width="7" height="7" rx="1" />
        <rect x="14" y="14" width="7" height="7" rx="1" />
      </svg>
      <span class="text-[11px] font-medium">Cards</span>
    </button>
    <button type="button" data-view="list" aria-pressed="false" class="view-btn px-3 py-2 rounded-md transition-all duration-150 flex items-center justify-center gap-1.5 flex-1">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
      <span class="text-[11px] font-medium">List</span>
    </button>
    <button type="button" data-view="glance" aria-pressed="false" class="view-btn px-3 py-2 rounded-md transition-all duration-150 flex items-center justify-center gap-1.5 flex-1">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <rect x="2" y="4" width="20" height="4" rx="1" />
        <rect x="2" y="10" width="20" height="4" rx="1" />
        <rect x="2" y="16" width="20" height="4" rx="1" />
      </svg>
      <span class="text-[11px] font-medium">Glance</span>
    </button>
  </div>

  <!-- Source filter -->
  <div class="flex items-center gap-1 overflow-x-auto pb-1 scrollbar-hide" role="group" aria-label="Filter by source">
    {sources.map((source) => (
      <button
        data-source={source.id}
        aria-pressed={source.id === 'all' ? 'true' : 'false'}
        class="source-btn px-3 py-1.5 rounded-md font-medium transition-all duration-150 whitespace-nowrap flex-shrink-0"
      >
        {source.label} <span class="source-badge text-[10px] opacity-70">(<span class="count">-</span>)</span>
      </button>
    ))}
  </div>
</div>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }

  /* View buttons — driven by aria-pressed */
  .view-btn {
    color: #64748b; /* slate-500 */
  }
  :global(.dark) .view-btn {
    color: #94a3b8; /* slate-400 */
  }
  .view-btn:where([aria-pressed="true"]) {
    background-color: #6366f1; /* primary-500 / indigo */
    color: #ffffff;
  }
  /* Only show hover bg on devices that truly support hover (not touch) */
  @media (hover: hover) {
    .view-btn:not([aria-pressed="true"]):hover {
      background-color: rgba(255,255,255,0.3);
    }
    :global(.dark) .view-btn:not([aria-pressed="true"]):hover {
      background-color: rgba(51,65,85,0.5); /* slate-700/50 */
    }
  }

  /* Source buttons */
  .source-btn {
    background-color: rgba(255,255,255,0.5);
    color: #475569; /* slate-600 */
  }
  :global(.dark) .source-btn {
    background-color: rgba(51,65,85,0.5);
    color: #94a3b8; /* slate-400 */
  }
  .source-btn:where([aria-pressed="true"]) {
    background-color: #6366f1;
    color: #ffffff;
  }
  @media (hover: hover) {
    .source-btn:not([aria-pressed="true"]):hover {
      background-color: #e0e7ff; /* primary-100 */
    }
    :global(.dark) .source-btn:not([aria-pressed="true"]):hover {
      background-color: rgba(99,102,241,0.2); /* primary-900/30 */
    }
  }
</style>

<script>
  function initFilters() {
    if ((window as typeof window & { __controlsInitialized?: boolean }).__controlsInitialized) {
      return;
    }
    (window as typeof window & { __controlsInitialized?: boolean }).__controlsInitialized = true;

    // Source buttons
    document.querySelectorAll('.source-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const source = btn.getAttribute('data-source');
        document.querySelectorAll('.source-btn').forEach((b) => b.setAttribute('aria-pressed', 'false'));
        btn.setAttribute('aria-pressed', 'true');
        btn.dispatchEvent(new CustomEvent('sourcechange', { detail: { source }, bubbles: true }));
      });
    });

    // View buttons
    document.querySelectorAll('.view-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const view = btn.getAttribute('data-view');
        document.querySelectorAll('.view-btn').forEach((b) => b.setAttribute('aria-pressed', 'false'));
        btn.setAttribute('aria-pressed', 'true');
        btn.dispatchEvent(new CustomEvent('viewchange', { detail: { mode: view }, bubbles: true }));
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initFilters);
</script>
