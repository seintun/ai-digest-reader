---
const sources = [
  { id: 'all', label: 'All' },
  { id: 'reddit', label: 'Reddit' },
  { id: 'hn', label: 'HackerNews' },
];
---

<div class="flex flex-col gap-2 text-xs">
  <div class="flex items-center gap-1 p-0.5 rounded-lg bg-white/30 dark:bg-slate-800/50">
    <button type="button" data-view="cards" class="view-btn active bg-primary-500 text-white px-3 py-2 rounded-md transition-all duration-150 flex items-center justify-center gap-1.5 flex-1">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="3" width="7" height="7" rx="1" />
        <rect x="14" y="3" width="7" height="7" rx="1" />
        <rect x="3" y="14" width="7" height="7" rx="1" />
        <rect x="14" y="14" width="7" height="7" rx="1" />
      </svg>
      <span class="text-[11px] font-medium">Cards</span>
    </button>
    <button type="button" data-view="list" class="view-btn text-slate-600 dark:text-slate-400 px-3 py-2 rounded-md transition-all duration-150 flex items-center justify-center gap-1.5 flex-1 hover:bg-white/30 dark:hover:bg-slate-700/50">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
      <span class="text-[11px] font-medium">List</span>
    </button>
    <button type="button" data-view="glance" class="view-btn text-slate-600 dark:text-slate-400 px-3 py-2 rounded-md transition-all duration-150 flex items-center justify-center gap-1.5 flex-1 hover:bg-white/30 dark:hover:bg-slate-700/50">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="2" y="4" width="20" height="4" rx="1" />
        <rect x="2" y="10" width="20" height="4" rx="1" />
        <rect x="2" y="16" width="20" height="4" rx="1" />
      </svg>
      <span class="text-[11px] font-medium">Glance</span>
    </button>
  </div>

  <div class="flex items-center gap-1 overflow-x-auto pb-1 scrollbar-hide">
    {sources.map((source) => (
      <button
        data-source={source.id}
        data-active={source.id === 'all' ? 'true' : 'false'}
        class:list={[
          'source-btn px-3 py-1.5 rounded-md font-medium transition-all duration-150 whitespace-nowrap flex-shrink-0',
          source.id === 'all'
            ? 'bg-primary-500 text-white'
            : 'bg-white/50 dark:bg-slate-700/50 text-slate-600 dark:text-slate-400 hover:bg-primary-100 dark:hover:bg-primary-900/30',
        ]}
      >
        {source.label} <span class="source-badge text-[10px] opacity-70">(<span class="count">-</span>)</span>
      </button>
    ))}
  </div>
</div>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  const SOURCE_ACTIVE_CLASSES = ['bg-primary-500', 'text-white'];
  const SOURCE_INACTIVE_CLASSES = ['bg-white/50', 'dark:bg-slate-700/50', 'text-slate-600', 'dark:text-slate-400'];

  function initFilters() {
    document.querySelectorAll('.source-btn').forEach((btn) => {
      const isActive = btn.getAttribute('data-active') === 'true';
      btn.classList.remove(...SOURCE_ACTIVE_CLASSES, ...SOURCE_INACTIVE_CLASSES);
      if (isActive) {
        btn.classList.add(...SOURCE_ACTIVE_CLASSES);
      } else {
        btn.classList.add(...SOURCE_INACTIVE_CLASSES);
      }
    });

    document.querySelectorAll('[data-source]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const source = btn.getAttribute('data-source');
        document.querySelectorAll('.source-btn').forEach((b) => {
          b.setAttribute('data-active', 'false');
          b.classList.remove(...SOURCE_ACTIVE_CLASSES);
          b.classList.add(...SOURCE_INACTIVE_CLASSES);
        });

        btn.setAttribute('data-active', 'true');
        btn.classList.add(...SOURCE_ACTIVE_CLASSES);
        btn.classList.remove(...SOURCE_INACTIVE_CLASSES);
        btn.dispatchEvent(new CustomEvent('sourcechange', { detail: { source }, bubbles: true }));
      });
    });

    document.querySelectorAll('.view-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const view = btn.getAttribute('data-view');
        document.querySelectorAll('.view-btn').forEach((b) => {
          b.classList.remove('bg-primary-500', 'text-white');
          b.classList.add('text-slate-600', 'dark:text-slate-400');
        });
        btn.classList.add('bg-primary-500', 'text-white');
        btn.classList.remove('text-slate-600', 'dark:text-slate-400');
        btn.dispatchEvent(new CustomEvent('viewchange', { detail: { mode: view }, bubbles: true }));
      });
    });
  }
  document.addEventListener('DOMContentLoaded', initFilters);
  initFilters();
</script>
