---
export interface Props {
  defaultView?: 'cards' | 'list' | 'glance';
}

const { defaultView = 'cards' } = Astro.props;
---

<div
  class="inline-flex items-center gap-1 p-1.5 rounded-xl bg-glass-light/50 dark:bg-glass-dark/50 backdrop-blur-[12px] border border-white/20 dark:border-white/10 shadow-lg"
  data-view-switcher
  data-default-view={defaultView}
  role="tablist"
  aria-label="View mode"
>
  <button
    type="button"
    role="tab"
    data-view="cards"
    aria-selected={defaultView === 'cards' ? 'true' : 'false'}
    class="view-btn group flex items-center gap-2 px-4 py-2.5 rounded-lg transition-all duration-200 touch-target min-h-[44px]"
  >
    <svg
      class="w-5 h-5 transition-colors duration-200"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <rect x="3" y="3" width="7" height="7" rx="1" />
      <rect x="14" y="3" width="7" height="7" rx="1" />
      <rect x="3" y="14" width="7" height="7" rx="1" />
      <rect x="14" y="14" width="7" height="7" rx="1" />
    </svg>
    <span class="hidden sm:inline text-sm font-medium">Cards</span>
  </button>

  <button
    type="button"
    role="tab"
    data-view="list"
    aria-selected={defaultView === 'list' ? 'true' : 'false'}
    class="view-btn group flex items-center gap-2 px-4 py-2.5 rounded-lg transition-all duration-200 touch-target min-h-[44px]"
  >
    <svg
      class="w-5 h-5 transition-colors duration-200"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <line x1="3" y1="6" x2="21" y2="6" />
      <line x1="3" y1="12" x2="21" y2="12" />
      <line x1="3" y1="18" x2="21" y2="18" />
    </svg>
    <span class="hidden sm:inline text-sm font-medium">List</span>
  </button>

  <button
    type="button"
    role="tab"
    data-view="glance"
    aria-selected={defaultView === 'glance' ? 'true' : 'false'}
    class="view-btn group flex items-center gap-2 px-4 py-2.5 rounded-lg transition-all duration-200 touch-target min-h-[44px]"
  >
    <svg
      class="w-5 h-5 transition-colors duration-200"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <rect x="2" y="4" width="20" height="4" rx="1" />
      <rect x="2" y="10" width="20" height="4" rx="1" />
      <rect x="2" y="16" width="20" height="4" rx="1" />
      <line x1="6" y1="6" x2="12" y2="6" />
      <line x1="6" y1="12" x2="16" y2="12" />
      <line x1="6" y1="18" x2="10" y2="18" />
    </svg>
    <span class="hidden sm:inline text-sm font-medium">Glance</span>
  </button>
</div>

<style>
  .view-btn {
    @apply text-slate-600 dark:text-slate-400;
  }

  .view-btn:hover {
    @apply text-slate-900 dark:text-slate-200;
    @apply bg-white/40 dark:bg-white/10;
  }

  .view-btn[data-active='true'] {
    @apply bg-primary-500 text-white shadow-md;
  }

  .view-btn[data-active='true'] svg {
    @apply text-white;
  }

  .view-btn[data-active='true']:hover {
    @apply bg-primary-600;
  }

  .view-btn:focus-visible {
    @apply outline-none ring-2 ring-primary-500 ring-offset-2 ring-offset-transparent;
  }
</style>

<script>
  function initViewSwitcher() {
    const switchers = document.querySelectorAll('[data-view-switcher]');

    switchers.forEach((container) => {
      const buttons = container.querySelectorAll('.view-btn');
      const defaultView = container.getAttribute('data-default-view') || 'cards';

      function setActive(view: string) {
        buttons.forEach((btn) => {
          const isActive = btn.getAttribute('data-view') === view;
          btn.setAttribute('data-active', isActive ? 'true' : 'false');
          btn.setAttribute('aria-selected', isActive ? 'true' : 'false');
        });

        container.dispatchEvent(
          new CustomEvent('viewchange', {
            detail: { mode: view },
            bubbles: true,
            composed: true,
          })
        );
      }

      buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const view = btn.getAttribute('data-view');
          if (view) setActive(view);
        });
      });

      setActive(defaultView);
    });
  }

  document.addEventListener('DOMContentLoaded', initViewSwitcher);
  initViewSwitcher();
</script>
