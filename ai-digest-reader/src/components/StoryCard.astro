---
import type { Story } from '../types';

interface Props {
  stories: Story[];
}

const { stories } = Astro.props;

function getSource(id: string): 'reddit' | 'hn' {
  return id.startsWith('rd-') ? 'reddit' : 'hn';
}

function formatScore(score: number): string {
  if (score >= 1000) {
    return `${(score / 1000).toFixed(1)}k`;
  }
  return score.toString();
}

function formatComments(comments: number): string {
  if (comments >= 1000) {
    return `${(comments / 1000).toFixed(1)}k`;
  }
  return comments.toString();
}
---

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
  {stories.map((story) => {
    const source = getSource(story.i);
    return (
      <article class="group relative backdrop-blur-md bg-white/70 dark:bg-slate-800/60 border border-white/20 dark:border-slate-700/50 rounded-2xl p-5 transition-all duration-300 hover:shadow-lg hover:shadow-primary-500/10 hover:-translate-y-1">
        <a 
          href={story.u} 
          target="_blank" 
          rel="noopener noreferrer"
          class="block"
        >
          <div class="flex items-center gap-2 mb-3">
            <span class={`inline-flex items-center px-2.5 py-1 rounded-md text-xs font-medium ${
              source === 'reddit' 
                ? 'bg-orange-100 text-orange-700 dark:bg-orange-900/30 dark:text-orange-400' 
                : 'bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-300'
            }`}>
              {source === 'reddit' ? (
                <svg class="w-3.5 h-3.5 mr-1" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/>
                </svg>
              ) : (
                <svg class="w-3.5 h-3.5 mr-1" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0L1.5 6v12L12 24l10.5-6V6L12 0zm0 2.3l8.3 5v9.4l-8.3 5-8.3-5V7.3l8.3-5z"/>
                </svg>
              )}
              {source === 'reddit' ? 'Reddit' : 'Hacker News'}
            </span>
          </div>

          <h3 class="text-lg font-medium text-slate-900 dark:text-white mb-2 line-clamp-2 group-hover:text-primary-500 dark:group-hover:text-primary-400 transition-colors duration-200">
            {story.t}
          </h3>

          <div class="flex items-center justify-between text-sm text-slate-500 dark:text-slate-400">
            <span class="truncate max-w-[120px]" title={story.a}>
              by {story.a}
            </span>
            <div class="flex items-center gap-3 ml-2">
              <span class="flex items-center gap-1" title="Score">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                </svg>
                {formatScore(story.s)}
              </span>
              <span class="flex items-center gap-1" title="Comments">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                </svg>
                {formatComments(story.c)}
              </span>
            </div>
          </div>
        </a>

        <div class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity duration-200">
          <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </div>
      </article>
    );
  })}
</div>
