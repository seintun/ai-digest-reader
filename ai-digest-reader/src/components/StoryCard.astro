---
import type { Story } from '../types';

interface Props {
  stories: Story[];
}

const { stories } = Astro.props;

function getSource(id: string): 'reddit' | 'hn' {
  return id.startsWith('rd-') ? 'reddit' : 'hn';
}

function formatScore(score: number): string {
  if (score >= 1000) {
    return `${(score / 1000).toFixed(1)}k`;
  }
  return score.toString();
}

function formatComments(comments: number): string {
  if (comments >= 1000) {
    return `${(comments / 1000).toFixed(1)}k`;
  }
  return comments.toString();
}


---

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
  {stories.map((story) => {
    const source = getSource(story.i);
    const discussionUrl = story.p || story.u;
    return (
      <article class="group relative bg-slate-900 border border-slate-800 rounded-xl p-5 transition-all duration-200 hover:border-amber-500/40 hover:shadow-[0_16px_40px_rgba(245,158,11,0.12)] flex flex-col">
        <a href={story.u} target="_blank" rel="noopener noreferrer" class="block min-h-[44px] cursor-pointer flex-1">
          <div class="flex items-start gap-2.5 mb-2">
            <div class="flex-shrink-0 mt-0.5" title={source === 'reddit' ? 'Reddit' : 'Hacker News'}>
              {source === 'reddit' ? (
                <svg class="w-4 h-4 text-[#FF4500] opacity-90" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/>
                </svg>
              ) : (
                <svg class="w-4 h-4 text-[#FF6600] opacity-90" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0L1.5 6v12L12 24l10.5-6V6L12 0zm0 2.3l8.3 5v9.4l-8.3 5-8.3-5V7.3l8.3-5z"/>
                </svg>
              )}
            </div>
            <h3 class="text-base font-bold text-slate-100 line-clamp-2 group-hover:text-amber-200 transition-colors duration-200 leading-snug">
              {story.t}
            </h3>
          </div>

          {story.b && (
            <p class="text-sm text-slate-400 line-clamp-3 mt-1 mb-2">
              {story.b}
            </p>
          )}
        </a>

        <div class="flex items-center justify-between mt-4 pt-3 border-t border-slate-800/60 gap-2">
          <div class="flex items-center gap-2 text-xs text-slate-500">
            <span class="inline-flex items-center gap-1 truncate max-w-[120px]" title={story.a}>
              <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A10.97 10.97 0 0112 15.5c2.6 0 4.99.9 6.879 2.304M15 9a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span class="truncate">{story.a}</span>
            </span>
            <span class="font-mono-data flex items-center gap-0.5" title="Score">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
              </svg>
              {formatScore(story.s)}
            </span>
          </div>
          <a
            href={discussionUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-3 w-full inline-flex items-center justify-center gap-2 px-3 py-2 rounded-lg text-xs font-medium bg-slate-800 text-slate-300 border border-slate-700 hover:bg-amber-500/10 hover:text-amber-300 hover:border-amber-500/40 transition-all duration-200 cursor-pointer"
            title="Join the discussion"
          >
            {source === 'reddit' ? (
              <svg class="w-3.5 h-3.5 text-[#FF4500]" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/>
              </svg>
            ) : (
              <svg class="w-3.5 h-3.5 text-[#FF6600]" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0L1.5 6v12L12 24l10.5-6V6L12 0zm0 2.3l8.3 5v9.4l-8.3 5-8.3-5V7.3l8.3-5z"/>
              </svg>
            )}
            <span>{formatComments(story.c)} comments on {source === 'reddit' ? 'Reddit' : 'Hacker News'}</span>
          </a>
        </div>
      </article>
    );
  })}
</div>
